{
  "name": "verdigloss",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "format:generated": "prettier --write src/assets/data/quiz-id-map.json",
    "generate-id-mapping": "node scripts/generate-id-mapping.js",
    "generate-data": "pnpm generate-id-mapping",
    "validate-data": "node scripts/validate-generated-data.js",
    "check-generated": "pnpm validate-data",
    "bundle:check": "node scripts/check-bundle-budget.js"
  },
  "dependencies": {
    "@vueuse/core": "^14.3.0",
    "vue": "^3.5.40",
    "vue-i18n": "^11.4.6",
    "vue-router": "^5.2.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@iconify-json/fa6-brands": "^1.2.6",
    "@iconify-json/material-symbols": "^1.2.85",
    "@intlify/unplugin-vue-i18n": "^11.2.4",
    "@playwright/test": "1.61.1",
    "@tailwindcss/vite": "^4.3.3",
    "@tsconfig/node24": "24.0.4",
    "@types/node": "^24.10.0",
    "@typescript-eslint/utils": "^8.64.0",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.9.0",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.7.0",
    "eslint-plugin-vue": "~10.9.2",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "npm-run-all2": "^9.0.2",
    "prettier": "3.9.5",
    "tailwindcss": "^4.3.3",
    "typescript": "~6.0.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-icons": "^23.0.1",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^8.1.4",
    "vite-plugin-vue-devtools": "^8.1.5",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.7"
  }
}
